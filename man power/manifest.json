{
  "manifest_version": 3,
  "name": "AI Prompt Enhancer",
  "version": "1.1.0",
  "description": "Universal AI Prompt Refiner - Works on ANY website with text inputs (Gemini, ChatGPT, Claude, and beyond)",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/ui/magic-wand.js",
        "src/content/universal-handler.js",
        "src/content/content-script.js"
      ],
      "css": [
        "src/ui/styles.css"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Prompt Enhancer Settings"
  }
}
